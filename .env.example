# BEGIN cloopy auto-managed (do not edit manually)
# END cloopy auto-managed

# ====================
# cloopy Configuration
# ====================
# Edit the values below to customize your environment.
# Run setup again to update the auto-managed block above.

# Instance name (default: cloopy)
# Used for Docker project name, SSH host, and volume prefix.
# CLOOPY_INSTANCE_NAME=cloopy

# SSH port (default: 10022)
# CLOOPY_SSH_PORT=10022

# Timezone (default: Asia/Tokyo)
# CLOOPY_TIMEZONE=Asia/Tokyo

# Host workspace path (default: ./workspace)
# CLOOPY_HOST_WORKSPACE=./workspace

# Egress firewall (default: on)
#   on  : default-DROP egress; only allowlisted domains are reachable.
#   off : permissive, but cloud metadata / RFC1918 / IPv6 stay blocked.
# CLOOPY_FIREWALL=on

# Extra domains to allow through the firewall (comma-separated).
# Example: CLOOPY_EXTRA_DOMAINS=mycompany.example.com,internal.api.com
# CLOOPY_EXTRA_DOMAINS=

