# BEGIN cloopy auto-managed (do not edit manually)
# END cloopy auto-managed

# ====================
# cloopy Configuration
# ====================
# Edit the values below to customize your environment.
# Run setup again to update the auto-managed block above.

# Instance name (default: cloopy)
# Used for Docker project name, SSH host, and volume prefix.
# CLOOPY_INSTANCE_NAME=cloopy

# SSH port (default: 10022)
# CLOOPY_SSH_PORT=10022

# Timezone (default: Asia/Tokyo)
# CLOOPY_TIMEZONE=Asia/Tokyo

# Host workspace path (default: ./workspace)
# CLOOPY_HOST_WORKSPACE=./workspace

# Egress firewall (default: on)
# on : block outbound traffic to cloud metadata services (169.254.169.254 etc.)
#      and private networks (10/8, 172.16/12, 192.168/16, CGNAT, IPv6 ULA).
#      Public internet egress is left fully open.
# off: kill switch — disables all egress filtering. Do NOT use on a cloud VM,
#      it re-exposes the instance metadata service (IMDS credential theft).
# CLOOPY_FIREWALL=on

# Allow the container to reach the Docker host via host.docker.internal
# (e.g. a dev server or database running on your machine). Default: on.
# The rest of the host's private network stays blocked by the firewall.
# CLOOPY_ALLOW_HOST=on

# Filtering DNS resolver (blocks malware/phishing domains at name resolution).
# The firewall pins DNS to these IPs and DROPs :53 to anything else, so the
# filter can't be bypassed by switching resolver. Default: Cloudflare for
# Families (malware scope — no adult-content filtering). Pick a row to switch:
#   Cloudflare malware : 1.1.1.2 / 1.0.0.2   (v6 2606:4700:4700::1112 / ::1002)
#   Quad9 security     : 9.9.9.9 / 149.112.112.112  (v6 2620:fe::fe / 2620:fe::9)
#   Cisco OpenDNS      : 208.67.222.222 / 208.67.220.220  (v6 2620:119:35::35 / 2620:119:53::53)
# To disable filtering, point these at a plain resolver (e.g. 1.1.1.1 / 1.0.0.1).
# CLOOPY_DNS_PRIMARY=1.1.1.2
# CLOOPY_DNS_SECONDARY=1.0.0.2
# CLOOPY_DNS_V6_PRIMARY=2606:4700:4700::1112
# CLOOPY_DNS_V6_SECONDARY=2606:4700:4700::1002

