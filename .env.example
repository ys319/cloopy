# --- Auto-managed by setup (do not edit manually) ---

# ====================
# cloopy Configuration
# ====================
# Edit the values below to customize your environment.
# Run setup again to regenerate auto-managed values above.

# SSH port (default: 10022)
# CLOOPY_SSH_PORT=10022

# Timezone (default: Asia/Tokyo)
# CLOOPY_TIMEZONE=Asia/Tokyo

# Host workspace path (default: ./workspace)
# CLOOPY_HOST_WORKSPACE=./workspace

# UID/GID override (default: 1000, usually no change needed)
# CLOOPY_USER_UID=1000
# CLOOPY_USER_GID=1000

# Use Docker volume for workspace instead of bind mount (recommended for Windows)
# CLOOPY_WORKSPACE_VOLUME=false

# Claude auth directory (set by setup if you chose to mount ~/.claude)
# CLOOPY_CLAUDE_HOME=
