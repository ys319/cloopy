{
  "imports": {
    "@cliffy/prompt": "jsr:@cliffy/prompt@^1.0.0",
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "@std/fmt/colors": "jsr:@std/fmt@^1.0.9/colors",
    "@std/path": "jsr:@std/path@^1.1.4"
  },
  "tasks": {
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "test": "deno test --allow-read --allow-write --allow-env",
    "check": "deno lint && deno fmt --check && deno test --allow-read --allow-write --allow-env"
  }
}
